# API Configuration for QA Auto System

# Primary API: OpenAI FuturePath ML
OPENAI_API_KEY_FUTUREPATH_ML=your_openai_futurepath_ml_key_here

# Secondary API: Azure OpenAI
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-azure-openai-endpoint.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Optional: Bytez API (fallback)
# BYTEZ_API_KEY=your_bytez_key_here
# BYTEZ_API_KEY_2=your_second_bytez_key_here

# Optional: DeepSeek API
# DEEPSEEK_API_KEY=your_deepseek_key_here

# Optional: Teams Integration
# TEAMS_WEBHOOK_URL=your_teams_webhook_url_here
